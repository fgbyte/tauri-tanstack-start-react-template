{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TauriTanstackStart",
  "version": "0.1.0",
  "identifier": "com.tryfgbyte.app",
  "build": {
    "beforeDevCommand": "bun dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "title": "tauri-tanstack-start-react-template",
        "width": 800,
        "height": 600,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "android": {
      "versionCode": 100,
      "minSdkVersion": 28
    },
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
